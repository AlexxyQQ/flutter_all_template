# ============================================================
# 🔐 Firebase / Secrets — DO NOT COMMIT REAL CREDENTIALS
# The placeholder versions of these files are tracked in git.
# After running `flutterfire configure`, git will see changes —
# use `git update-index --assume-unchanged <file>` to suppress
# them locally, or add your real files to a private branch.
# ============================================================
# Uncomment these lines to prevent git from tracking real keys:
# android/app/google-services.json
# ios/Runner/GoogleService-Info.plist
# lib/config/firebase/firebase_options.dart
# brick/__brick__/android/app/google-services.json
# brick/__brick__/ios/Runner/GoogleService-Info.plist
# brick/__brick__/lib/config/firebase/firebase_options.dart

# Environment files (real values — never commit)
env/.env
.env